{
  "name": "webfetch",
  "version": "0.1.0",
  "description": "Smart web fetching CLI with tiered escalation and content extraction",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HJewkes/webfetch.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "webfetch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "defuddle": "^0.7.0",
    "node-html-markdown": "^2.0.0",
    "undici": "^7.0.0"
  },
  "optionalDependencies": {
    "patchright": "^1.57.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
