{
  "name": "webfetch",
  "version": "0.1.0",
  "description": "Smart web fetching CLI with tiered escalation and content extraction",
  "type": "module",
  "bin": {
    "webfetch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome check ."
  },
  "dependencies": {
    "commander": "^14.0.0",
    "defuddle": "^0.7.0",
    "jsdom": "^25.0.0",
    "node-html-markdown": "^2.0.0",
    "patchright": "^1.57.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
